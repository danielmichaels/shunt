#!/bin/sh

# Conventional Commits validation
# https://www.conventionalcommits.org/en/v1.0.0/
# Types from @commitlint/config-conventional

commit_msg_file="$1"
commit_msg=$(head -1 "$commit_msg_file")

# Skip merge commits and revert commits generated by git
if echo "$commit_msg" | grep -qE "^Merge (branch|remote-tracking|pull request|tag) "; then
  exit 0
fi
if echo "$commit_msg" | grep -qE "^Revert \""; then
  exit 0
fi

types="build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test"
pattern="^($types)(\([a-zA-Z0-9._-]+\))?!?: .+$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected: <type>(<optional scope>): <description>"
  echo "  Got:      $commit_msg"
  echo ""
  echo "  Allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test"
  echo ""
  echo "  Examples:"
  echo "    feat: add user authentication"
  echo "    fix(parser): handle empty input"
  echo "    feat!: remove deprecated API"
  echo "    chore(deps): bump go version to 1.23"
  echo ""
  echo "  See: https://www.conventionalcommits.org/en/v1.0.0/"
  exit 1
fi

SIGNED_OFF="Signed-off-by: $(git config user.name) <$(git config user.email)>"

if ! grep -qi "^Signed-off-by:" "$commit_msg_file"; then
  printf "\nSigned-off-by: %s <%s>\n" "$(git config user.name)" "$(git config user.email)" >> "$commit_msg_file"
fi
